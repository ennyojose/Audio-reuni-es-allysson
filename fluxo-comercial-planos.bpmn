<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_VendaPlanos" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="Lead Entra (Bitrix, Whats, Indicação)">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_EntenderEvento" name="Entender o Evento (Triagem)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_EntenderEvento" />
    <bpmn:task id="Task_EnviarFormulario" name="Enviar Form. e Apresentação">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_EntenderEvento" targetRef="Task_EnviarFormulario" />
    <bpmn:task id="Task_AgendarReuniao" name="Agendar Reunião Consultiva">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_EnviarFormulario" targetRef="Task_AgendarReuniao" />
    <bpmn:task id="Task_RealizarReuniao" name="Realizar Reunião e Demonstrar Sistema">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_AgendarReuniao" targetRef="Task_RealizarReuniao" />
    <bpmn:task id="Task_PrepararProposta" name="Preparar Proposta (Múltiplos Planos)">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_RealizarReuniao" targetRef="Task_PrepararProposta" />
    <bpmn:task id="Task_EnviarProposta" name="Enviar Proposta (Em até 24h)">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_PrepararProposta" targetRef="Task_EnviarProposta" />
    <bpmn:exclusiveGateway id="Gateway_Negociacao" name="Aprovado?">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_Aprovado</bpmn:outgoing>
      <bpmn:outgoing>Flow_Rejeitado</bpmn:outgoing>
      <bpmn:outgoing>Flow_Ajustes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_EnviarProposta" targetRef="Gateway_Negociacao" />
    <bpmn:task id="Task_Fechamento" name="Fechar Contrato (Bitrix)">
      <bpmn:incoming>Flow_Aprovado</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Aprovado" name="Sim" sourceRef="Gateway_Negociacao" targetRef="Task_Fechamento" />
    <bpmn:task id="Task_AjustarProposta" name="Ajustar Proposta / Aditivos">
      <bpmn:incoming>Flow_Ajustes</bpmn:incoming>
      <bpmn:outgoing>Flow_VoltaAjuste</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Ajustes" name="Solicitou Alteração" sourceRef="Gateway_Negociacao" targetRef="Task_AjustarProposta" />
    <bpmn:sequenceFlow id="Flow_VoltaAjuste" sourceRef="Task_AjustarProposta" targetRef="Task_EnviarProposta" />
    <bpmn:endEvent id="EndEvent_1" name="Venda Perdida">
      <bpmn:incoming>Flow_Rejeitado</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Rejeitado" name="Não" sourceRef="Gateway_Negociacao" targetRef="EndEvent_1" />
    <bpmn:task id="Task_PassarLogistica" name="Passar para Equipe de Logística">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_Fechamento" targetRef="Task_PassarLogistica" />
    <bpmn:endEvent id="EndEvent_Sucesso" name="Evento em Andamento">
      <bpmn:incoming>Flow_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_End" sourceRef="Task_PassarLogistica" targetRef="EndEvent_Sucesso" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_VendaPlanos">
      <bpmndi:BPMNShape id="_BPMNShape_StartEvent_2" bpmnElement="StartEvent_1">
        <dc:Bounds x="150" y="200" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="133" y="243" width="70" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1_di" bpmnElement="Task_EntenderEvento">
        <dc:Bounds x="240" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="186" y="218" />
        <di:waypoint x="240" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Activity_2_di" bpmnElement="Task_EnviarFormulario">
        <dc:Bounds x="400" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="340" y="218" />
        <di:waypoint x="400" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Activity_3_di" bpmnElement="Task_AgendarReuniao">
        <dc:Bounds x="560" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="500" y="218" />
        <di:waypoint x="560" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Activity_4_di" bpmnElement="Task_RealizarReuniao">
        <dc:Bounds x="720" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="660" y="218" />
        <di:waypoint x="720" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Activity_5_di" bpmnElement="Task_PrepararProposta">
        <dc:Bounds x="880" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="820" y="218" />
        <di:waypoint x="880" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Activity_6_di" bpmnElement="Task_EnviarProposta">
        <dc:Bounds x="1040" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="980" y="218" />
        <di:waypoint x="1040" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Gateway_1_di" bpmnElement="Gateway_Negociacao" isMarkerVisible="true">
        <dc:Bounds x="1205" y="193" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1203" y="169" width="54" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="1140" y="218" />
        <di:waypoint x="1205" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Activity_7_di" bpmnElement="Task_Fechamento">
        <dc:Bounds x="1320" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Aprovado_di" bpmnElement="Flow_Aprovado">
        <di:waypoint x="1255" y="218" />
        <di:waypoint x="1320" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1212" y="322" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1194" y="365" width="73" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Rejeitado_di" bpmnElement="Flow_Rejeitado">
        <di:waypoint x="1230" y="243" />
        <di:waypoint x="1230" y="322" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1235" y="280" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Activity_8_di" bpmnElement="Task_AjustarProposta">
        <dc:Bounds x="1040" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Ajustes_di" bpmnElement="Flow_Ajustes">
        <di:waypoint x="1230" y="243" />
        <di:waypoint x="1230" y="340" />
        <di:waypoint x="1140" y="340" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1160" y="306" width="46" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_VoltaAjuste_di" bpmnElement="Flow_VoltaAjuste">
        <di:waypoint x="1090" y="300" />
        <di:waypoint x="1090" y="258" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Activity_9_di" bpmnElement="Task_PassarLogistica">
        <dc:Bounds x="1480" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1420" y="218" />
        <di:waypoint x="1480" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="EndEvent_S_di" bpmnElement="EndEvent_Sucesso">
        <dc:Bounds x="1642" y="200" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1631" y="243" width="58" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_End_di" bpmnElement="Flow_End">
        <di:waypoint x="1580" y="218" />
        <di:waypoint x="1642" y="218" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
